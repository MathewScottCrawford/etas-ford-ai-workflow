Purpose: Sample modified ARXML for arxml_diff.py testing
=============================================================================
-->
<AUTOSAR xmlns="http://autosar.org/schema/r4.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://autosar.org/schema/r4.0 AUTOSAR_00048.xsd">
  <AR-PACKAGES>

    <!-- ── ECU Instance ─────────────────────────────────────────────────── -->
    <AR-PACKAGE>
      <SHORT-NAME>EcuInstance</SHORT-NAME>
      <ELEMENTS>
        <ECU-INSTANCE>
          <SHORT-NAME>ECU_Powertrain</SHORT-NAME>
          <COMM-CONTROLLERS>
            <COM-CONTROLLER>
              <SHORT-NAME>CAN_Controller_0</SHORT-NAME>
              <ECU-COM-PORT-INSTANCES/>
            </COM-CONTROLLER>
            <!-- ADDED: second CAN controller for gateway function -->
            <COM-CONTROLLER>
              <SHORT-NAME>CAN_Controller_1</SHORT-NAME>
              <ECU-COM-PORT-INSTANCES/>
            </COM-CONTROLLER>
          </COMM-CONTROLLERS>
        </ECU-INSTANCE>
      </ELEMENTS>
    </AR-PACKAGE>

    <!-- ── COM Stack ────────────────────────────────────────────────────── -->
    <AR-PACKAGE>
      <SHORT-NAME>COM_Config</SHORT-NAME>
      <ELEMENTS>

        <!-- Signal: EngineSpeed — LENGTH changed 16 -> 32 (wider signal) -->
        <I-SIGNAL>
          <SHORT-NAME>EngineSpeed_Sig</SHORT-NAME>
          <LENGTH>32</LENGTH>
          <INIT-VALUE>
            <NUMERICAL-VALUE-SPECIFICATION>
              <VALUE>0</VALUE>
            </NUMERICAL-VALUE-SPECIFICATION>
          </INIT-VALUE>
          <TRANSFER-PROPERTY>TRIGGERED</TRANSFER-PROPERTY>
        </I-SIGNAL>

        <!-- Signal: VehicleSpeed — TRANSFER-PROPERTY changed TRIGGERED -> PENDING -->
        <I-SIGNAL>
          <SHORT-NAME>VehicleSpeed_Sig</SHORT-NAME>
          <LENGTH>16</LENGTH>
          <INIT-VALUE>
            <NUMERICAL-VALUE-SPECIFICATION>
              <VALUE>0</VALUE>
            </NUMERICAL-VALUE-SPECIFICATION>
          </INIT-VALUE>
          <TRANSFER-PROPERTY>PENDING</TRANSFER-PROPERTY>
        </I-SIGNAL>

        <!-- Signal: ThrottlePosition — unchanged -->
        <I-SIGNAL>
          <SHORT-NAME>ThrottlePosition_Sig</SHORT-NAME>
          <LENGTH>8</LENGTH>
          <INIT-VALUE>
            <NUMERICAL-VALUE-SPECIFICATION>
              <VALUE>0</VALUE>
            </NUMERICAL-VALUE-SPECIFICATION>
          </INIT-VALUE>
          <TRANSFER-PROPERTY>TRIGGERED</TRANSFER-PROPERTY>
        </I-SIGNAL>

        <!-- Signal: BrakePressure — ADDED -->
        <I-SIGNAL>
          <SHORT-NAME>BrakePressure_Sig</SHORT-NAME>
          <LENGTH>16</LENGTH>
          <INIT-VALUE>
            <NUMERICAL-VALUE-SPECIFICATION>
              <VALUE>0</VALUE>
            </NUMERICAL-VALUE-SPECIFICATION>
          </INIT-VALUE>
          <TRANSFER-PROPERTY>TRIGGERED</TRANSFER-PROPERTY>
        </I-SIGNAL>

        <!-- PDU: Powertrain Status PDU — LENGTH changed 8 -> 16 -->
        <I-PDU>
          <SHORT-NAME>PT_Status_PDU</SHORT-NAME>
          <LENGTH>16</LENGTH>
          <PDU-TO-FRAME-MAPPING>
            <SHORT-NAME>PT_Status_Mapping</SHORT-NAME>
          </PDU-TO-FRAME-MAPPING>
        </I-PDU>

        <!-- PDU: Engine Control PDU — unchanged -->
        <I-PDU>
          <SHORT-NAME>Engine_Control_PDU</SHORT-NAME>
          <LENGTH>8</LENGTH>
          <PDU-TO-FRAME-MAPPING>
            <SHORT-NAME>Engine_Control_Mapping</SHORT-NAME>
          </PDU-TO-FRAME-MAPPING>
        </I-PDU>

        <!-- PDU: Brake Status PDU — ADDED -->
        <I-PDU>
          <SHORT-NAME>Brake_Status_PDU</SHORT-NAME>
          <LENGTH>8</LENGTH>
          <PDU-TO-FRAME-MAPPING>
            <SHORT-NAME>Brake_Status_Mapping</SHORT-NAME>
          </PDU-TO-FRAME-MAPPING>
        </I-PDU>

      </ELEMENTS>
    </AR-PACKAGE>

    <!-- ── OS Configuration ─────────────────────────────────────────────── -->
    <AR-PACKAGE>
      <SHORT-NAME>OS_Config</SHORT-NAME>
      <ELEMENTS>

        <OS-APPLICATION>
          <SHORT-NAME>OsApp_Powertrain</SHORT-NAME>
          <TRUSTED>true</TRUSTED>
        </OS-APPLICATION>

        <!-- OsTask_10ms — PRIORITY changed 5 -> 7 (potential timing risk) -->
        <TASK>
          <SHORT-NAME>OsTask_10ms</SHORT-NAME>
          <PRIORITY>7</PRIORITY>
          <PERIOD>10</PERIOD>
          <ACTIVATION>1</ACTIVATION>
          <STACK-SIZE>512</STACK-SIZE>
        </TASK>

        <!-- OsTask_100ms — STACK-SIZE changed 512 -> 1024 -->
        <TASK>
          <SHORT-NAME>OsTask_100ms</SHORT-NAME>
          <PRIORITY>3</PRIORITY>
          <PERIOD>100</PERIOD>
          <ACTIVATION>1</ACTIVATION>
          <STACK-SIZE>1024</STACK-SIZE>
        </TASK>

        <!-- OsTask_5ms — ADDED (new fast task) -->
        <TASK>
          <SHORT-NAME>OsTask_5ms</SHORT-NAME>
          <PRIORITY>9</PRIORITY>
          <PERIOD>5</PERIOD>
          <ACTIVATION>1</ACTIVATION>
          <STACK-SIZE>256</STACK-SIZE>
        </TASK>

      </ELEMENTS>
    </AR-PACKAGE>

    <!-- ── DCM / Diagnostics ─────────────────────────────────────────────── -->
    <AR-PACKAGE>
      <SHORT-NAME>DCM_Config</SHORT-NAME>
      <ELEMENTS>

        <!-- DID_0xF190 — unchanged -->
        <DIAGNOSTIC-DATA-IDENTIFIER>
          <SHORT-NAME>DID_0xF190</SHORT-NAME>
          <IDENTIFIER>61840</IDENTIFIER>
          <DATA-LENGTH>17</DATA-LENGTH>
        </DIAGNOSTIC-DATA-IDENTIFIER>

        <!-- DID_0xF187 — DATA-LENGTH changed 10 -> 14 -->
        <DIAGNOSTIC-DATA-IDENTIFIER>
          <SHORT-NAME>DID_0xF187</SHORT-NAME>
          <IDENTIFIER>61831</IDENTIFIER>
          <DATA-LENGTH>14</DATA-LENGTH>
        </DIAGNOSTIC-DATA-IDENTIFIER>

        <!-- DID_0xF101 — ADDED (new calibration DID) -->
        <DIAGNOSTIC-DATA-IDENTIFIER>
          <SHORT-NAME>DID_0xF101</SHORT-NAME>
          <IDENTIFIER>61697</IDENTIFIER>
          <DATA-LENGTH>4</DATA-LENGTH>
        </DIAGNOSTIC-DATA-IDENTIFIER>

        <DIAGNOSTIC-SESSION>
          <SHORT-NAME>DefaultSession</SHORT-NAME>
          <SESSION-LEVEL>1</SESSION-LEVEL>
        </DIAGNOSTIC-SESSION>

        <!-- ProgrammingSession — REMOVED (ExtendedDiagnosticSession added instead) -->

        <!-- ExtendedDiagnosticSession — ADDED -->
        <DIAGNOSTIC-SESSION>
          <SHORT-NAME>ExtendedDiagnosticSession</SHORT-NAME>
          <SESSION-LEVEL>3</SESSION-LEVEL>
        </DIAGNOSTIC-SESSION>

      </ELEMENTS>
    </AR-PACKAGE>

  </AR-PACKAGES>
</AUTOSAR>
