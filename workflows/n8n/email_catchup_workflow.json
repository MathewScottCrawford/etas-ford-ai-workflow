    {
      "parameters": {
        "promptType": "define",
        "text": "=You are an email analyst. Analyze this LinkedIn email and extract structured information.\n\nEmail Details:\nSubject: {{ $json.subject }}\nFrom: {{ $json.from }}\nDate: {{ $json.date }}\nContent: {{ $json.body }}\n\nExtract and return ONLY a JSON object with exactly these fields:\n{\n  \"recruiter_name\": \"full name of the recruiter or sender\",\n  \"company_name\": \"company they are recruiting for\",\n  \"position_title\": \"job title or role mentioned\",\n  \"email_type\": \"one of: job_opportunity, connection_request, follow_up, other\",\n  \"summary\": \"one sentence summary of the email\"\n}\nReturn ONLY a raw JSON object on a single line.\nNo markdown. No backticks. No explanation. No newlines.\nExample output: {\"recruiter_name\":\"Jane Smith\",\"company_name\":\"Acme Corp\",\"position_title\":\"Software Engineer\",\"email_type\":\"job_opportunity\",\"summary\":\"Recruiter reached out about a senior engineering role.\"}",
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        1024,
        -384
      ],
      "id": "f9b152fc-0697-407e-8e81-8135919d8b90",
      "name": "Extract LinkedIn Data"
    },
    {
      "parameters": {
        "jsCode": "const items_out = [];\n\nfor (const item of items) {\n  // The LLM response comes back in output field\n  const rawText = item.json.output || item.json.text || '';\n  \n  let parsed = {};\n  try {\n    // Strip any accidental markdown backticks just in case\n    const cleaned = rawText\n      .replace(/```json/g, '')\n      .replace(/```/g, '')\n      .trim();\n    parsed = JSON.parse(cleaned);\n  } catch(e) {\n    // If parsing fails, log it and continue\n    parsed = {\n      recruiter_name: 'PARSE_ERROR',\n      company_name: 'PARSE_ERROR', \n      position_title: 'PARSE_ERROR',\n      email_type: 'unknown',\n      summary: rawText.substring(0, 200)\n    };\n  }\n\n  items_out.push({\n    json: {\n      // Pass through original fields we need\n      message_id:     item.json.message_id,\n      date:           item.json.date,\n      // Add parsed LLM fields\n      recruiter_name: parsed.recruiter_name || '',\n      company_name:   parsed.company_name || '',\n      position_title: parsed.position_title || '',\n      email_type:     parsed.email_type || '',\n      summary:        parsed.summary || '',\n    }\n  });\n}\n\nreturn items_out;"
      },
