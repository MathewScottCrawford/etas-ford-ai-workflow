    {
      "parameters": {
        "jsCode": "const items_out = [];\n\nfor (const item of items) {\n  const msg = item.json;\n  \n  // Extract label names as a flat array\n  const labelNames = (msg.labels || []).map(l => l.name);\n  \n  // Build clean normalized object\n  items_out.push({\n    json: {\n      message_id:   msg.id,\n      thread_id:    msg.threadId,\n      subject:      msg.Subject || msg.subject || '(no subject)',\n      from:         msg.From || msg.from || '',\n      to:           msg.To || msg.to || '',\n      snippet:      msg.snippet || '',\n      date:         msg.internalDate \n                      ? new Date(parseInt(msg.internalDate)).toISOString()\n                      : '',\n      labels:       labelNames,\n      is_unread:    labelNames.includes('UNREAD'),\n      is_inbox:     labelNames.includes('INBOX'),\n      account:      'gmail',\n      // body will be added in next iteration\n      // keeping this field present for schema consistency\n      body:         msg.body || msg.snippet || '',\n    }\n  });\n}\n\nreturn items_out;"
      },
